{
  "name": "dejitter",
  "version": "1.0.5",
  "description": "Browser-injectable animation recorder & jank detector. Records every rAF at full speed, downsamples intelligently, and auto-detects jitter, flicker, shiver, jumps, stutter, stuck, and outliers.",
  "main": "index.js",
  "module": "index.mjs",
  "exports": {
    ".": {
      "import": "./index.mjs",
      "require": "./index.js"
    },
    "./recorder": "./recorder.js"
  },
  "files": [
    "index.js",
    "index.mjs",
    "recorder.js",
    "README.md"
  ],
  "scripts": {
    "test": "playwright test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wende/dejitter.git"
  },
  "keywords": [
    "animation",
    "jitter",
    "jank",
    "recorder",
    "requestAnimationFrame",
    "performance",
    "debugging",
    "flicker",
    "shiver",
    "stutter",
    "stuck"
  ],
  "author": "wende",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/wende/dejitter/issues"
  },
  "homepage": "https://github.com/wende/dejitter#readme",
  "devDependencies": {
    "@playwright/test": "^1.58.2"
  }
}
